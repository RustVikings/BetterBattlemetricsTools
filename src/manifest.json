{
    "manifest_version": 3,
    "name": "Better Battlemetrics Tools",
    "description": "Needs a proper description",
    "version": "1.0.0",
    "action": {
        "default_icon": {
            "16": "icons/icon_16.png",
            "48": "icons/icon_48.png",
            "128": "icons/icon_128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://battlemetrics.com/*",
                "*://www.battlemetrics.com/*"
            ],
            "js": ["main.js"],
            "run_at": "document_idle"
        }
    ],

    "icons": {
        "16": "icons/icon_16.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "host_permissions": [
        "*://api.battlemetrics.com/*",
        "*://api.steampowered.com/*"
    ],
    "permissions": [
        "tabs",
        "activeTab",
        "notifications",
        "scripting",
        "storage"
    ],
    "options_page": "index.html",
    "background": {
        "scripts": ["worker.js"],
        "service_worker": "worker.js",
        "type": "module",
        "persistent": "false"
    }
}
