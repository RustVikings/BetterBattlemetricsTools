{
    "manifest_version": 3,
    "name": "Better Battlemetrics Tools",
    "description": "This extension changes the layout of the \"Player profile\" page and enhances the presented information.",
    "version": "0.1.0",
    "action": {
        "default_icon": {
            "16": "icons/icon_16.png",
            "48": "icons/icon_48.png",
            "128": "icons/icon_128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://battlemetrics.com/*",
                "*://www.battlemetrics.com/*"
            ],
            "js": ["main.js"],
            "run_at": "document_end"
        }
    ],

    "icons": {
        "16": "icons/icon_16.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "host_permissions": [
        "*://api.battlemetrics.com/*",
        "*://api.steampowered.com/*"
    ],
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "storage",
        "webNavigation"
    ],
    "options_page": "index.html",
    "background": {
        "service_worker": "worker.js",
        "type": "module",
        "scripts": ["worker.js"]
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/copy.svg",
                "icons/kill.svg",
                "icons/death.svg"
            ],
            "matches": [
                "*://www.battlemetrics.com/*",
                "*://battlemetrics.com/*"
            ]
        }
    ]
}
